# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Authentication ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
RESET_KEY=
SECRET_KEY=change-me-in-production

# ── Bitwarden ─────────────────────────────────────────────────────────────────
# Option A — Personal API key (recommended for full automation, no manual login ever)
# Get your key from: Bitwarden web vault → Account Settings → Security → Keys
# The master password is still required because Bitwarden encrypts the vault with it.
# Security note: these values have the same exposure as any other secret in .env.
BW_CLIENT_ID=
BW_CLIENT_SECRET=
BW_MASTER_PASSWORD=
# Self-hosted Vaultwarden server URL (leave blank for bitwarden.com)
BW_SERVER_URL=

# Option B — Pre-supply an existing session token (expires; manual refresh needed)
BW_SESSION=

# ── Scanning ────────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=360
CACHE_MAX_AGE_HOURS=4
# Max minutes a scan may run before its lock is considered stale (default 30)
SCAN_TIMEOUT_MINUTES=30

# ── Auto-rotation ────────────────────────────────────────────────────────────────
# Set to a number > 0 to enable scheduled auto-rotation of stale secrets.
# 0 = disabled (default). Example: 168 = rotate stale services weekly.
AUTO_ROTATE_INTERVAL_HOURS=0

# ── Notifications ────────────────────────────────────────────────────────────────
# Webhook URL for rotation event notifications (leave blank to disable).
WEBHOOK_URL=
# Webhook format: generic (default), discord, slack, gotify
WEBHOOK_TYPE=generic

# ── Key Discovery ────────────────────────────────────────────────────────────────
# Comma or colon-separated filesystem paths to scan for API keys
DISCOVERY_SEARCH_DIRS=/mnt/user/appdata,/boot/config,/opt,/home
# Comma-separated directory names to skip during scan (virtual/system filesystems)
DISCOVERY_SKIP_DIRS=proc,sys,dev,run,tmp,boot,snap,lost+found

# ── Paths ───────────────────────────────────────────────────────────────────────
ENV_FILE=.env
DESCRIPTIONS_PATH=rotate_keys.yaml
DATA_DIR=/app/data
DOCKER_SOCKET=/var/run/docker.sock
