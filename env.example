# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Authentication ──────────────────────────────────────────────────────────────
# REQUIRED: Set a strong secret key (32+ characters recommended).
# The app will refuse to start with the default value.
# WARNING: Changing SECRET_KEY will invalidate existing session cookies and
# encrypted discovered key values. If you change it, re-run key discovery.
SECRET_KEY=change-me-in-production
# For bcrypt-hashed passwords: generate with python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=
RESET_KEY=

# ── Bitwarden ─────────────────────────────────────────────────────────────────
# Option A — Personal API key (recommended for full automation, no manual login ever)
# Get your key from: Bitwarden web vault → Account Settings → Security → Keys
# The master password is still required because Bitwarden encrypts the vault with it.
# Security note: BW_MASTER_PASSWORD is stored in plaintext in this file. For better
# security, consider using Docker secrets or a file-based credential approach.
BW_CLIENT_ID=
BW_CLIENT_SECRET=
BW_MASTER_PASSWORD=
# Self-hosted Vaultwarden server URL (leave blank for bitwarden.com)
BW_SERVER_URL=
# Session timeout in minutes (0 = no timeout, session lasts until container restart).
# Recommended: 60 for production. The app will re-authenticate automatically if
# API key credentials are configured.
BW_SESSION_TIMEOUT_MINUTES=0

# Option B — Pre-supply an existing session token (expires; manual refresh needed)
BW_SESSION=

# ── Crypto ────────────────────────────────────────────────────────────────────────
# KDF salt for encrypting discovered keys at rest. If not set, a default salt is
# used (less secure — all deployments with the same SECRET_KEY derive the same key).
# Set this to a unique random string for each deployment.
KDF_SALT=

# ── Scanning ────────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=360
CACHE_MAX_AGE_HOURS=4
# Max minutes a scan may run before its lock is considered stale (default 30)
SCAN_TIMEOUT_MINUTES=30

# ── Auto-rotation ────────────────────────────────────────────────────────────────
# Set to a number > 0 to enable scheduled auto-rotation of stale secrets.
# 0 = disabled (default). Example: 168 = rotate stale services weekly.
AUTO_ROTATE_INTERVAL_HOURS=0

# ── Notifications ────────────────────────────────────────────────────────────────
# Webhook URL for rotation event notifications (leave blank to disable).
# Only HTTPS URLs are allowed for security (no http://, no private/internal IPs).
# Examples: https://discord.com/api/webhooks/..., https://hooks.slack.com/...
WEBHOOK_URL=
# Webhook format: generic (default), discord, slack, gotify
WEBHOOK_TYPE=generic

# ── Key Discovery ────────────────────────────────────────────────────────────────
# Comma or colon-separated filesystem paths to scan for API keys
DISCOVERY_SEARCH_DIRS=/mnt/user/appdata,/boot/config,/opt,/home
# Comma-separated directory names to skip during scan (virtual/system filesystems)
DISCOVERY_SKIP_DIRS=proc,sys,dev,run,tmp,boot,snap,lost+found

# ── Paths ───────────────────────────────────────────────────────────────────────
ENV_FILE=.env
DESCRIPTIONS_PATH=rotate_keys.yaml
DATA_DIR=/app/data
DOCKER_SOCKET=/var/run/docker.sock

# ── Security ────────────────────────────────────────────────────────────────────
# Set to false ONLY for local development. Session cookies will be sent over HTTP.
COOKIE_HTTPS_ONLY=true
# Set to true to skip SSL verification for health check URLs (insecure, local only)
HEALTH_CHECK_SKIP_SSL=false
