# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Authentication ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
RESET_KEY=
SECRET_KEY=change-me-in-production

# ── Bitwarden ─────────────────────────────────────────────────────────────────
# Optional: pre-supply a session token. If omitted, unlock via the web UI.
BW_SESSION=

# ── Scanning ────────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=360
CACHE_MAX_AGE_HOURS=4

# ── Paths ───────────────────────────────────────────────────────────────────────
ENV_FILE=.env
DESCRIPTIONS_PATH=rotate_keys.yaml
DATA_DIR=/app/data
DOCKER_SOCKET=/var/run/docker.sock
